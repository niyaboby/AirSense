# Copy this file to .env and fill in your keys.

# Google Gemini API key — https://aistudio.google.com/
GEMINI_API_KEY=

# WAQI (World Air Quality Index) — free token: https://aqicn.org/data-platform/token/
WAQI_TOKEN=

# NASA FIRMS — free map key: https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY=

# Anthropic Claude API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Server port
PORT=8787

# Comma-separated allowed CORS origin(s) for the frontend
CORS_ORIGIN=http://localhost:5173
